# MongoDB — set automatically by docker-compose, but can be overridden
# MONGODB_URI=mongodb://mongo:27017/maqder

# Server
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Frontend URL (used by CORS and email links)
FRONTEND_URL=https://maqder.com

# ZATCA / E-invoicing
ZATCA_MODE=production

# Email SMTP (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Cloud storage for backups and uploads (optional)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# WhatsApp / other integrations (optional)

# Cloudflare OAuth for tenant domain auto-DNS (optional)
# Register an OAuth app at https://dash.cloudflare.com/profile/api-tokens to obtain these
# CLOUDFLARE_OAUTH_CLIENT_ID=your_cloudflare_oauth_client_id
# CLOUDFLARE_OAUTH_CLIENT_SECRET=your_cloudflare_oauth_client_secret
# CLOUDFLARE_FALLBACK_ORIGIN=origin.maqder.com
