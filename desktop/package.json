{
  "name": "maqder-desktop",
  "version": "1.0.0",
  "description": "Maqder Desktop App for ZATCA Phase 1 Offline Invoicing",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.maqder.desktop",
    "productName": "Maqder Desktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "shortcutName": "Maqder Desktop"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://maqder.com/downloads/updates/"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.1.7",
    "nedb-promises": "^6.2.1",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
